{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0", // <--- AGREGA ESTA LÍNEA AQUÍ
    "outDir": "./dist"
  },
  "include": ["**/*.ts"]
}